# Cortex — obrigatório para dados reais do Ploomes
PLOOMES_API_KEY=sua-chave-aqui

# Neppo (WhatsApp) — opcional
# NEPPO_CLIENT_KEY=
# NEPPO_CLIENT_SECRET=
# NEPPO_USERNAME=
# NEPPO_PASSWORD=

# IA (OpenRouter) — opcional
# OPENROUTER_API_KEY=
# CORTEX_AI_MODEL=openrouter/free

# Segurança do webhook (OBRIGATÓRIO em produção) — chave que o Neppo/Ploomes
# devem enviar em ?key=... ou no header X-Webhook-Key. Sem ela, o webhook é
# recusado (a menos que WEBHOOK_ALLOW_INSECURE=1, só para dev local).
# WEBHOOK_VALIDATION_KEY=uma-chave-bem-grande-aleatoria
# WEBHOOK_ALLOW_INSECURE=1

# Servindo por HTTPS? marque para os cookies de sessão irem como Secure:
# SECURE_COOKIES=1
# Origens extras permitidas no CORS (separadas por vírgula):
# CORS_ORIGINS=https://painel.suaempresa.com.br

# Só para desenvolvimento sem Ploomes (dados fictícios):
# CORTEX_USE_MOCK=1
