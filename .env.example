# Cortex — obrigatório para dados reais do Ploomes
PLOOMES_API_KEY=sua-chave-aqui

# Neppo (WhatsApp) — opcional
# NEPPO_CLIENT_KEY=
# NEPPO_CLIENT_SECRET=
# NEPPO_USERNAME=
# NEPPO_PASSWORD=

# IA (OpenRouter) — opcional
# OPENROUTER_API_KEY=
# CORTEX_AI_MODEL=openrouter/free

# Só para desenvolvimento sem Ploomes (dados fictícios):
# CORTEX_USE_MOCK=1
